# Telegram Bot
TG_BOT_TOKEN=<YOUR_TELEGRAM_BOT_TOKEN>
TG_WEBHOOK_URL=
TG_WEBHOOK_SECRET=replace-with-random-secret

# Auto-filled by `tg-codex init --token <TG_BOT_TOKEN>`.
# Ensure you have sent /start to the bot first so updates contain your chat/user ids.
TG_ALLOWED_CHAT_IDS=
TG_ALLOWED_USER_IDS=
# Optional admin overrides (default = same as allowed ids)
TG_ADMIN_CHAT_IDS=
TG_ADMIN_USER_IDS=

# Codex runner
# Command prefix. Prompt is appended as the last argument.
CODEX_COMMAND_PREFIX=codex -a never exec --full-auto
CODEX_TIMEOUT_SECONDS=600
TG_ALLOW_PLAIN_TEXT=0
TG_ALLOW_CMD_OVERRIDE=0
TG_MAX_IMAGE_BYTES=10485760
TG_MAX_BUFFERED_OUTPUT_CHARS=200000
TG_MAX_CONCURRENT_TASKS=2
# Optional second-factor auth: require /auth <passphrase> before /run and /cmd.
TG_AUTH_PASSPHRASE=
TG_AUTH_TTL_SECONDS=43200
